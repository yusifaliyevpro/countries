{
  "compilerOptions": {
    "target": "es2023",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "isolatedDeclarations": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  // `tests` is checked by its own tests/tsconfig.json — it needs the vitest
  // globals and the src alias, neither of which belong in the library's config.
  "include": ["src", "scripts"],
  "exclude": ["node_modules", "dist"]
}
